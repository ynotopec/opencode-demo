# Copy to .env and adjust values for your setup.
# The script auto-loads .env from this repository root.

# Optional: if empty/unset, ./opencode.sh up will prompt interactively.
OPENCODE_SERVER_PASSWORD=

# Optional SSH target overrides (defaults shown)
# OPENCODE_REMOTE_USER=openclaw
# OPENCODE_REMOTE_HOST=openclaw
# OPENCODE_REMOTE_DIR=work

# Optional local mount and ports (defaults shown)
# OPENCODE_LOCAL_MOUNT=$HOME/work
# OPENCODE_LOCAL_PORT=8080
# OPENCODE_REMOTE_PORT=8080

# Optional extra runtime flags for `opencode web`
# OPENCODE_WEB_EXTRA_ARGS=

# Optional SSH host key behavior (defaults shown)
# OPENCODE_SSH_STRICT_HOST_KEY_CHECKING=accept-new
# OPENCODE_SSH_USER_KNOWN_HOSTS_FILE=$HOME/.ssh/known_hosts
